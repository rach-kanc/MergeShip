# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Run `npx supabase status` to get these keys after `make supabase-start`
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# GitHub App (mandatory install gate)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=mergeship
# Local default — sim-webhook signs with this. Replace with a real secret only
# when wiring a real GitHub App.
GITHUB_WEBHOOK_SECRET=dev-secret

# Redis — local docker-compose (docker compose up -d redis)
# Uncomment REDIS_URL below to use it. If both are blank, uses in-memory fallback.
# REDIS_URL=redis://localhost:6379

# Production Redis (Upstash) - Takes precedence over REDIS_URL if set
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Groq (LLM)
GROQ_API_KEY=
GROQ_BUDGET_PER_DAY=400000

# Observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local-only flags (defaults: mock everything so contributors don't need real keys)
MOCK_GITHUB_API=true
MOCK_GITHUB_WEBHOOKS=true
MOCK_LLM=true

# Public app URL (for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3001
